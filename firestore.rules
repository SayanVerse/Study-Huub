rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only access their own data (path-specific CRUD)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow collectionGroup queries on "notes" — used for Starred tab
    match /{path=**}/notes/{noteId} {
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).id == request.auth.uid
        && path[1] == request.auth.uid;
    }

    // Allow collectionGroup queries on "files" — used for Starred tab
    match /{path=**}/files/{fileId} {
      allow read: if request.auth != null
        && path[1] == request.auth.uid;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
